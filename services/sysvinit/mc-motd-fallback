#!/bin/sh /etc/rc.common

START=95
STOP=01
USE_PROCD=1

SERVICE_NAME="motd-fallback"
HAPROXY_DIR="${HAPROXY_DIR:-/root/haproxy}"
LUA_SCRIPT="$HAPROXY_DIR/motd_server.lua"

start_service() {
    procd_open_instance
    procd_set_param command /usr/bin/lua $LUA_SCRIPT
    procd_set_param respawn 2000 5 5
    procd_set_param stdout 1
    procd_set_param stderr 1
    procd_set_param pidfile /var/run/$SERVICE_NAME.pid
    procd_close_instance
}

stop_service() {
    local pid
    pid=$(cat /var/run/$SERVICE_NAME.pid 2>/dev/null)
    if [ -n "$pid" ]; then
        kill "$pid" 2>/dev/null
        rm -f /var/run/$SERVICE_NAME.pid
    fi
}
